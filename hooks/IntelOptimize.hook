    .dc.l   @UserUnit__GetMaxCounterIntel



# Interestingly, the only blueprints fields to ever use uints are in the exact
# intel fields we wish to change - we will simply change
# `gpg::RType::AddFieldUInt` method to use the float type. If the function
# calls were identical, we would have simply called `gpg::RType::AddFieldFloat`,
# though this approach has the added benefit of also affecting the
# `Moho::SMinMaxUint32` that the jamming and spoofing relies on.
gpg__RType__float = 0x010A6320
type_info__float = 0x00F5C858
#gpg::RType::AddFieldUInt@0x0040E020
0x0040E041:
    mov     eax, [gpg__RType__float]
0x0040E04A:
    push    type_info__float
0x0040E057:
    mov     [gpg__RType__float], eax



# disable update code for the intel grids, which only processes the unused
# delayed circle subtraction system - if it did work, it would not rasterize
# properly because it uses the default rasterer
0x005C1434: #Moho::CAiReconDBImpl::ReconTick+0x7F3
    jmp     0x005C14B5

# nuke the default rasterer in case anyone manages to find it
0x00507540: #Moho::CIntelGrid::Raster
    ret     4

# we just nuked the default rasterer that our destructors rely on; substitute
# our own
0x0076D86F: #Moho::CIntelPosHandle::~CIntelPosHandle+0xF
    call    @CIntelPosHandle__SubViz
    jmp     0x0076D88E # the method was inlined, so the rest needs to be skipped

0x0076DA8B: #Moho::CIntelCounterHandle::~CIntelCounterHandle+0x2B
    call    @CIntelCounterHandle__SubViz



