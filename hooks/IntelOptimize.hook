


# entry points for our system

# apparently, it's much easier to manage the calling code in assembly
# than to make assembly adapters in c++
0x0076E4C0: #Moho::CIntel::Update
    mov     eax, [esp+0x8]
    push    ecx
    push    ebp
    push    esi
    push    edi
    mov     ecx, [esp+0x10+0x4]  # this
    push    eax                  # curTick
    push    ebx                  # newPos
    call    @CIntel__Update
    pop     edi
    pop     esi
    pop     ebp
    pop     ecx
    ret     8

0x0076F1E0: #Moho::CIntelPosHandle::UpdatePos
    push    ecx
    push    ebx
    push    esi
    push    eax       # curTick
    push    ecx       # newPos
    mov     ecx, edx  # this
    call    @CIntelPosHandle__UpdatePos
    pop     esi
    pop     ebx
    pop     ecx
    ret



