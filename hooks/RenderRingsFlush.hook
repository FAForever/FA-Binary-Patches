// Fix range ring stencil overflow with 128+ overlapping units.
//
// Background: func_RenderRings (0x007EF5A0) renders range rings via two
// loops sharing the same "Cast" effect technique that increments the GPU
// stencil per overdraw layer. The stencil is 7-bit (max 127), so 128+
// overlapping rings cause counter wrap-around and the early-out optimization
// fails -- individual circle outlines appear instead of a unified shape.
//
// Loop 1 (0x007EF774-0x007EF7FC) draws the FILL of the ring band (1 quad
// per ring, high per-pixel overdraw on overlap) -- this is the loop that
// overflows. Loop 2 draws only the thin EDGE strips (2 quads per ring) and
// has near-zero per-pixel overdraw, so it does not need patching.
//
// Fix: reduce Loop 1 batch size from 1000 to 128, and inject an intermediate
// RangeMask flush between batches that resets the stencil counter.
//
// === Calling Conventions ===
//
// The three engine functions called here use a custom register-based thiscall
// (verified in the engine's call sites at 0x007EF820-0x007EF849):
//   - 0x007F5DA0: CRenFrame::InitTransformedVerts: this @ EBX
//   - 0x004059E0: std::string::string: this @ ECX (standard MSVC thiscall)
//   - 0x007F6030: CRenFrame::Render: this @ EDI
// A direct C++ call is impossible since no C++ calling convention puts `this`
// in EBX or EDI. The arguments and calling sequences are hardcoded in asm.

// Loop 1 batch cap: cmp eax, 0x3E8  ->  cmp eax, 128
// (patches the imm32 of the 5-byte 'cmp eax, imm32' instruction at 0x007EF77D)
0x007EF77E:
    .int 128

// Loop 1 batch ceiling: mov eax, 0x3E8  ->  mov eax, 128
// (patches the imm32 of the 5-byte 'mov eax, imm32' instruction at 0x007EF784)
0x007EF785:
    .int 128

// Inject intermediate RangeMask flush at the bottom of the Loop 1 body.
// Replaces the 7-byte 'mov eax, [esp+0x84]' with a 5-byte call + 2 NOPs.
// IntermediateRangeMask reproduces the replaced instruction after the flush.


0x007EF76E:
    jle     L_ExitRangeRender

rangeRenderer = 4
idx = 8
frame = 0x10
i = 0x14
0x007EF7EA:
    mov     eax, [esp+0x70+idx]
    mov     edi, [esp+0x70+rangeRenderer]   # load rangeRenderer (CRenFrame container)
    add     edi, 0x4C                       # &rangeRenderer->mFrame
    mov     [esp+0x70+frame], edi
    cvtsi2ss xmm0, dword ptr [eax+0x14]     # height
    movd    ebx, xmm0
    push    ebx
    cvtsi2ss xmm0, dword ptr [eax+0x10]     # width
    movd    ebx, xmm0
    push    ebx
    mov     ebx, edi
    call    0x007F5DA0                   # Moho::CRenFrame::InitTransformedVerts(float,float)
    push    9                            # len
    push    0x00E3F8E8                   # "RangeMask" string address
    mov     ecx, edi                     # this
    call    0x004059E0                   # std::string::string(char const *,uint)
    mov     eax, [esp+0x70+idx]
    push    [eax+0x14]                   # height
    push    [eax+0x10]                   # width
    call    0x007F6030                   # Moho::CRenFrame::Render(int,int)
    mov     eax, [esp+0x70+i]           # load loop counter
    add     eax, esi                     # i += increment
    cmp     eax, ebp                     # compare with end
    mov     [esp+0x70+i], eax           # store updated counter
    jl      0x7EF774
L_ExitRangeRender:
    nop;nop