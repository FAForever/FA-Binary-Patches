0x0068E960: #cfunc_EntityGetIntelRadius+0x110
    movd    xmm0, eax



# floating-point conversions to use `Moho::VisionDB::Handle::Update` correctly
0x008C0CC7: #Moho::UserUnit::Tick+0x297
    # slide instructions up to hide floating->int conversion
    movss   [esp+0x24], xmm0
    push    ecx
    lea     ecx, [esp+0x24]
    # now move value directly to function argument
    mov     [esp+0], edi
    jmp     0x008C0CE5

0x008B950D: #Moho::UserEntity::UpdateEntityData+0x64D
    mov     ecx, [esp+0x14]
    # slide instructions up to hide floating->int conversion
    movss   [esp+0x20], xmm0
    movss   xmm0, dword ptr [edi+0x8C]
    movss   [esp+0x24], xmm0
    movss   xmm0, dword ptr [edi+0xA0]
    movss   [esp+0x28], xmm0
    movss   xmm0, dword ptr [edi+0xA8]
    movss   [esp+0x2C], xmm0
    push    ecx
    lea     eax, [esp+0x2C]
    # now move value directly to function argument
    mov     edi, [esp+0x18]
    mov     [esp+0], edi
    jmp     0x008B955A



