
# change non-trail effects to update visibility every tick instead of every 5 ticks
0x0065C520: #Moho::CEfxEmitter::CanSeeCam+0x100
    jnz     .+0x2C
0x00655ADB: #Moho::CEfxBeam::CanSeeCam+0x43B
    jnz     .+0x25

# change emitter effects to update position every tick instead of every 3 ticks
0x0065DADE: #Moho::CEfxEmitter::OnTick+0x1E
    ja      .+0x36
0x0065DAF0: #Moho::CEfxEmitter::OnTick+0x30
    jmp     .+0x24
