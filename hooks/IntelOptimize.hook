# The following sections are likely not needed as floats and ints have the same
# size, and floats fit fine in general-purpose registers for moving purposes
# even if the compiler won't put them there.
# However, they are included for completeness.

# update the serialization process for Moho::CIntelPosHandleSerializer (this is
# what Moho::CIntelCounterHandleSerializer will also end up using) and for
# Moho::EntityAttributesSerializer

# Moho::EntityAttributes stores if the intel field is enabled in the first bit
# and the range in the rest - this is fine to reinterpret as floats as the first
# bit is now the sign bit (see 0x005BD530, 0x005BD470, and 0x008B8330)

# from `gpg::ReadArchive->ReadUInt` to `gpg::ReadArchive->ReadFloat`
#Moho::CIntelPosHandle::MemberDeserialize+0x45
0x00770045: # mRadius
    mov     edx, [eax+0xC]
#Moho::EntityAttributes::MemberDeserialize@0x00559350
0x0055935C: # mVision
    mov     edx, [eax+0xC]
0x00559366: # mWaterVision
    mov     edx, [eax+0xC]
0x00559373: # mRadar
    mov     edx, [eax+0xC]
0x00559380: # mSonar
    mov     edx, [eax+0xC]
0x0055938D: # mOmni
    mov     edx, [eax+0xC]
0x0055939A: # mRadarStealth
    mov     edx, [eax+0xC]
0x005593A7: # mSonarStealth
    mov     edx, [eax+0xC]
0x005593B4: # mCloak
    mov     edx, [eax+0xC]

